{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin staging:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Bash(node:*)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:developer.intuit.com)",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:code.claude.com)"
    ],
    "ask": [
      "Bash(git push origin main:*)",
      "Bash(git push origin main)",
      "Bash(git push:* main)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
